# Gemini API Key (server-side only, get free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
# Optional: rotate/failover across multiple keys. Keep GEMINI_API_KEY for backwards compatibility.
# Example: GEMINI_API_KEYS=key_1,key_2,key_3
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# Optional: override default model order.
# Recommended for best speed, reading quality & intelligence: gemini-2.5-flash
# For maximum intelligence (slower/more expensive): gemini-2.5-pro
# For lowest latency/cost (slightly less smart): gemini-2.5-flash-lite
# Default fallback order (7 models, 3 geracoes para maximizar tentativas em caso de cota esgotada):
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-1.5-flash,gemini-1.5-pro,gemini-1.5-flash-8b
GEMINI_MAX_OUTPUT_TOKENS=65536
GEMINI_PROXY_RATE_LIMIT_MAX=30

# Redis Configuration
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Supabase Configuration (Alternative to Redis)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional, server-side only: allows /api/users and /api/track to read/write every usage row even with RLS enabled.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PostgreSQL Configuration
DATABASE_URL=postgresql://username:password@hostname:port/database?sslmode=require
